# DeepSeek LLM Configuration
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# PDK profile. Add profiles in pdk_profiles.py; override fields below per machine.
CIRCUIT_AGENT_PDK=tsmc28

# PDK Configuration — HSPICE format (.cir / .sp)
PDK_HSPICE_PATH=/PDKS/TSMC28nm/models/hspice/toplevel.l
PDK_HSPICE_SECTION=TOP_TT

# PDK Configuration — Spectre format (.scs)
PDK_SPECTRE_PATH=/mnt/hgfs/Share/PDKS/TSMC28nm/models/spectre/toplevel.scs
PDK_SPECTRE_SECTION=top_tt
PDK_PROCESS_SECTIONS=tt:top_tt,ss:top_ss,ff:top_ff
NMOS_MODEL=nch_mac
PMOS_MODEL=pch_mac
NMOS_LVT_MODEL=nch_lvt_mac
PMOS_LVT_MODEL=pch_lvt_mac
VDD=0.9
VDD_MIN=0.9
VDD_MAX=1.1
PDK_MIN_L=120e-9
PDK_MAX_WIDTH_PER_FINGER=2.6e-6
PDK_MIN_WIDTH_PER_FINGER=0.2e-6
VIRTUOSO_TECH_LIB=tsmcN28
VIRTUOSO_PDK_LIB_PATH=/PDKS/TSMC28nm/tsmcN28

# gm/Id lookup table path. Override this for a different PDK/project.
GMID_TABLE_PATH=../../gmid_lookup_table/gm_id_tables_tsmc28.json

# Optimization Configuration
MAX_ITERATIONS=50
LLM_VALIDATION_FREQUENCY=5
SPECTRE_TIMEOUT=300

# Paths (relative to circuit_agent/)
WORKSPACE_DIR=./workspace
KNOWLEDGE_BASE_DIR=./knowledge_base
OUTPUTS_DIR=./outputs
