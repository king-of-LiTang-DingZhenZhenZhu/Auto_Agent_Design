# DeepSeek LLM Configuration
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# PDK Configuration — HSPICE format (.cir / .sp)
PDK_HSPICE_PATH=/PDKS/TSMC28nm/models/hspice/toplevel.l
PDK_HSPICE_SECTION=TOP_TT

# PDK Configuration — Spectre format (.scs)
PDK_SPECTRE_PATH=/mnt/hgfs/Share/PDKS/TSMC28nm/models/spectre/toplevel.scs
PDK_SPECTRE_SECTION=top_tt

# Optimization Configuration
MAX_ITERATIONS=50
LLM_VALIDATION_FREQUENCY=5
SPECTRE_TIMEOUT=300

# Paths (relative to circuit_agent/)
WORKSPACE_DIR=./workspace
KNOWLEDGE_BASE_DIR=./knowledge_base
OUTPUTS_DIR=./outputs
